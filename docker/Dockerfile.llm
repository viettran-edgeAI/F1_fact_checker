ARG L4T_TAG=r36.4.0

FROM nvcr.io/nvidia/l4t-jetpack:${L4T_TAG}

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_NO_CACHE_DIR=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app/src \
    LLM_HOST=0.0.0.0 \
    LLM_PORT=8081 \
    LLAMA_SERVER_BIN=/opt/llama.cpp/build/bin/llama-server \
    LLM_CTX_SIZE=12288 \
    LLM_MAX_OCR_CHARS=6000 \
    LLM_MAX_TOKENS=512 \
    LLM_TEMPERATURE=0.2 \
    LLM_TOP_P=0.95 \
    LLM_TOP_K=40 \
    LLM_PARALLEL=1 \
    LLM_GPU_LAYERS=0 \
    LLM_DEVICE=none \
    LLM_FLASH_ATTN=off \
    LLM_FIT=off \
    LLM_KV_OFFLOAD=0 \
    LLM_OP_OFFLOAD=0 \
    LLM_DISABLE_THINKING=1 \
    LD_LIBRARY_PATH=/opt/llama.cpp/build/bin:/usr/local/cuda/lib64:/usr/lib/aarch64-linux-gnu/nvidia:${LD_LIBRARY_PATH}

ARG DEPS_CACHE_BUSTER=0

RUN apt-get update \
    && echo "Dependency rebuild marker: ${DEPS_CACHE_BUSTER}" >/dev/null \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        libgomp1 \
        python3 \
        python3-pip \
    && rm -rf /var/lib/apt/lists/*

COPY third_party/llama-bin/bin /opt/llama.cpp/build/bin

WORKDIR /app

COPY requirements/llm.txt /app/requirements-llm.txt
RUN python3 -m pip install --upgrade pip setuptools wheel \
    && python3 -m pip install -r /app/requirements-llm.txt

COPY src /app/src

EXPOSE 8081

HEALTHCHECK --interval=30s --timeout=5s --start-period=180s --retries=3 \
    CMD python3 -c "import json, urllib.request; urllib.request.urlopen('http://127.0.0.1:8081/healthz', timeout=5).read()"

CMD ["python3", "-m", "llm_service.main"]
