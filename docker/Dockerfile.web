FROM python:3.10-slim

ENV PIP_NO_CACHE_DIR=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app/src \
    WEB_HOST=0.0.0.0 \
    WEB_PORT=8080 \
    WEB_APP_DATA_DIR=/app/data/web_app \
    OCR_SERVICE_URL=http://ocr:8000 \
    LLM_SERVICE_URL=http://llm:8081 \
    WEB_APP_OWNER_EMAIL= \
    WEB_APP_COOKIE_SECURE=0

ARG DEPS_CACHE_BUSTER=0

WORKDIR /app

COPY requirements/web.txt /app/requirements-web.txt
RUN echo "Dependency rebuild marker: ${DEPS_CACHE_BUSTER}" >/dev/null \
    && python -m pip install --upgrade pip setuptools wheel \
    && python -m pip install -r /app/requirements-web.txt

COPY src /app/src
COPY README.md /app/README.md
COPY docs/web_app.md /app/web_app.md

RUN mkdir -p /app/data/web_app/uploads /app/data/web_app/ocr_markdown

EXPOSE 8080

CMD ["python", "-m", "web_app.main"]
